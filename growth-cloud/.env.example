# Swell Growth Cloud — environment variables
# Copy to .env and fill in. Settings loaded by ingest/config.py.

# ─── Required for ingest ──────────────────────────────────────────────────────
# Anthropic API key (Claude Sonnet ≥4.5). Used by both AID extraction and the
# recompile worker.
ANTHROPIC_API_KEY=

# Fathom API key. Not required when running ingest with --fixtures.
FATHOM_API_KEY=

# Absolute path to the Growth Cloud workspace (folder containing /clients and
# /wiki). Defaults to the CLI's --workspace flag if unset.
GROWTH_CLOUD_WORKSPACE=

# ─── Optional ─────────────────────────────────────────────────────────────────
# Override the Anthropic model SKU. Default: claude-sonnet-4-5-20250929.
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# JSON object mapping invitee email domains to client slugs.
# Example: '{"target-darts.com": "target-darts", "verisure.com": "verisure"}'
CLIENT_DOMAIN_MAP={}

# Fallback client slug for calls whose domain isn't mapped. Leave empty to
# silently skip them.
# CLIENT_DEFAULT=

# How far back to look on each poll, in hours. Default: 24.
# INGEST_LOOKBACK_HOURS=24

# Watch-mode poll interval in minutes. Default: 15.
# INGEST_POLL_INTERVAL_MIN=15

# ─── Plumbing ─────────────────────────────────────────────────────────────────
# Path to the llmwiki checkout. If unset, the CLI probes ../llmwiki/ relative
# to growth-cloud/.
# LLMWIKI_ROOT=/abs/path/to/llmwiki

# Stable local user UUID for SQLite isolation. If unset, derived from
# uuid5(NAMESPACE_DNS, "local") — matches llmwiki's default so both tools
# share one workspace row.
# LLMWIKI_USER_ID=
