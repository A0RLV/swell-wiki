#!/usr/bin/env bash
# Growth Cloud launcher — used by Claude Desktop's mcpServers.command and by
# humans who haven't `pip install -e .`-ed the package.
#
# Resolution order for the Python interpreter:
#   1. $GROWTH_CLOUD_PYTHON if set
#   2. <repo>/.venv/bin/python if it exists
#   3. python3 on PATH

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PYTHONPATH="${REPO_ROOT}${PYTHONPATH:+:${PYTHONPATH}}"

if [[ -n "${GROWTH_CLOUD_PYTHON:-}" ]]; then
    PY="$GROWTH_CLOUD_PYTHON"
elif [[ -x "${REPO_ROOT}/.venv/bin/python" ]]; then
    PY="${REPO_ROOT}/.venv/bin/python"
else
    PY="$(command -v python3 || command -v python)"
fi

exec "$PY" -m server.cli "$@"
